rules_version = '2';
service firebase.storage {
  match /b/{bucket}/o {
    // Helper functions
    function isAuthenticated() {
      return request.auth != null;
    }
    
    function isOwner(userId) {
      return isAuthenticated() && request.auth.uid == userId;
    }

    // User-specific storage (e.g., avatars, private vault)
    match /users/{userId}/{allPaths=**} {
      allow read: if isOwner(userId);
      allow write: if isOwner(userId) && request.resource.size < 10 * 1024 * 1024; // 10MB limit
    }

    // Public assets (if any)
    match /public/{allPaths=**} {
      allow read: if true;
      allow write: if false; // Only via Admin SDK
    }
    
    // CreatorBook Vault (Secure storage for master files)
    match /vault/{userId}/{allPaths=**} {
      allow read: if isOwner(userId);
      allow write: if isOwner(userId) && request.resource.size < 100 * 1024 * 1024; // 100MB limit
    }
  }
}
